# ── crawlcraft configuration ──────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# All settings are also overridable via environment variables
# with the CRAWL_ prefix (e.g. CRAWL_REDPANDA_BOOTSTRAP_SERVERS).

# ── Redpanda ──────────────────────────────────────────────────────
CRAWL_REDPANDA_BOOTSTRAP_SERVERS=172.16.10.3:9092
CRAWL_REDPANDA_TOPIC_PREFIX=crawl
CRAWL_REDPANDA_BATCH_SIZE=16384
CRAWL_REDPANDA_LINGER_MS=1000
CRAWL_REDPANDA_COMPRESSION=lz4
CRAWL_REDPANDA_ACKS=1
CRAWL_REDPANDA_MAX_RETRIES=3

# ── Daemon ────────────────────────────────────────────────────────
CRAWL_DAEMON_PORT=8910
CRAWL_DAEMON_HOST=127.0.0.1

# ── Data ──────────────────────────────────────────────────────────
# CRAWL_DATA_DIR=~/.crawlcraft
