# ── Docker 部署专用配置 ──────────────────────────────────────────
# 复制到 docker.env 并调整，会自动挂载到容器内。

CRAWL_REDPANDA_BOOTSTRAP_SERVERS=172.16.10.3:9092
CRAWL_REDPANDA_TOPIC_PREFIX=crawl
CRAWL_REDPANDA_LINGER_MS=1000
CRAWL_DAEMON_PORT=8910

# Docker 必须监听 0.0.0.0 才能接收宿主机请求
CRAWL_DAEMON_HOST=0.0.0.0

# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
